{
  "name": "sc101-lab-interface",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:backend":  "npm --prefix backend start",
    "dev:frontend": "npm --prefix frontend run dev",
    "build":        "npm --prefix frontend run build",
    "start":        "./start.sh",
    "dev":          "concurrently -k -p \"[{name}]\" -n \"backend,frontend\" -c \"yellow,cyan\" \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
